{
  "manifest_version": 3,
  "name": "AutoApply - Job Application Autofill",
  "version": "1.0.0",
  "description": "Automatically fill job applications on LinkedIn, Internshala, Wellfound, and Indeed",
  
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "webRequest"
  ],

  "host_permissions": [
    "http://localhost:3000/*",
    "https://www.linkedin.com/*",
    "https://internshala.com/*",
    "https://wellfound.com/*",
    "https://indeed.com/*",
    "https://www.linkedin.com/jobs/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://internshala.com/jobs*",
        "https://wellfound.com/jobs*",
        "https://wellfound.com/role/*",
        "https://indeed.com/jobs*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://localhost:3000/autofill*"
      ],
      "js": ["web-bridge.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AutoApply"
  }
}
